{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Download Bunny",
  "version": "0.1.0",
  "identifier": "com.thecotne.download-bunny",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Download Bunny",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBMjIxOERGNzUyMUQ1MzkKUldRNTFTRjEzeGdpT3NlT1RQdTNvWEhkb1pPYXZBZytlZC9aUTN1eEV4KzBDWEs1bGV6eHEwNUMK",
      "endpoints": [
        "https://github.com/thecotne/download-bunny/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
